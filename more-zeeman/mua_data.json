  "vocabularies": [
    {
      "description": "Algebraic-expression vocabulary: variables, literals, operators, assignments, sub-expressions, evaluation.",
      "id": "v_algebraic_expression"
    },
    {
      "description": "Area-model justification vocabulary: re-grounds a procedural fraction rule by deriving its output from the area-model kernel and comparing.",
      "id": "v_area_justification"
    },
    {
      "description": "Area-model vocabulary for fraction multiplication. Names the unit square, side-partitions, sub-rectangles, and selected area as part-of-part.",
      "id": "v_area_model"
    },
    {
      "description": "Bijective counting and the five counting principles: one-to-one correspondence, stable order, cardinal, abstraction, order-irrelevance.",
      "id": "v_bijective_counting"
    },
    {
      "description": "Place-value column-algorithm vocabulary. Names columns, carries, regroupings, place-values.",
      "id": "v_column_algorithm"
    },
    {
      "description": "Counting words and the count-from-one practice. Source domain vocabulary for the Object-Collection metaphor.",
      "id": "v_counting"
    },
    {
      "description": "The Counting-On vocabulary: start at the larger addend and count the smaller. Implicit associativity but no explicit decomposition.",
      "id": "v_counting_on"
    },
    {
      "description": "The rule (a/b) * (c/d) = (a*c)/(b*d) as a pure pattern. Names numerators, denominators, and the multiply-across operation. Without a kernel justification this vocabulary is held without an LX-elaboration.",
      "id": "v_cross_multiplication_rule"
    },
    {
      "description": "The decimal-multiplication rule: multiply digits as integers, place the decimal by summing fractional-place counts.",
      "id": "v_decimal_multiplication_rule"
    },
    {
      "description": "Decimal-positional notation: whole part, fractional part, place-unit, decimal point.",
      "id": "v_decimal_positional"
    },
    {
      "description": "Validation by distributive decomposition: a product is validated by summing partial products over an additive decomposition of one factor.",
      "id": "v_distributive_decomposition"
    },
    {
      "description": "Comparison-of-rounding-errors vocabulary: names what each candidate estimate omits and selects the estimate whose omission has the smaller magnitude.",
      "id": "v_error_magnitude_comparison"
    },
    {
      "description": "Fraction-as-unit vocabulary. Names the referent whole, equal partitions, the unit fraction, and iteration of the unit.",
      "id": "v_fraction_unit"
    },
    {
      "description": "Function-limit vocabulary: substitution at a continuous point, factor-cancel reduction, tail bound.",
      "id": "v_function_limit"
    },
    {
      "description": "Validation by inverse multiplication: the divisor times a proposed quotient must not exceed the dividend.",
      "id": "v_inverse_multiplication"
    },
    {
      "description": "Compensation / making-a-base vocabulary. Names the base, the decomposition, the transfer, and the conservation of total.",
      "id": "v_make_base_transfer"
    },
    {
      "description": "Multiplicative ratio scaling: scale factor preserves the unit ratio across both terms.",
      "id": "v_ratio_scaling"
    },
    {
      "description": "Sequence-convergence vocabulary: bounded numerator, diverging denominator, epsilon-N tail bound.",
