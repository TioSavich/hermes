  "practices": [
    {
      "description": "Partition the unit square into B vertical strips, take A; partition each into D horizontal slices, take C. Names the part-of-part.",
      "id": "p_area_model_part_of_part"
    },
    {
      "description": "Decompose and recombine by base-and-ones place value.",
      "id": "p_base_ones_chunking"
    },
    {
      "description": "Sequence convergence: bounded numerator over diverging denominator goes to zero via epsilon-N tail bound.",
      "id": "p_bounded_numerator_over_diverging_denominator"
    },
    {
      "description": "Column-by-column addition with carrying. LX-elaboration of base-ones chunking with explicit carry vocabulary.",
      "id": "p_column_addition_with_carrying"
    },
    {
      "description": "Counting-On from the larger addend: a strategy that says nothing explicit about commutativity but presupposes it.",
      "id": "p_count_on_from_larger"
    },
    {
      "description": "Productive cross-multiplication: executes the rule AND carries an area-model justification. LX-elaboration of the area-model practice.",
      "id": "p_cross_multiplication_rule_from_pattern"
    },
    {
      "description": "Deformation: the cross-multiplication rule held without the area-model justification. Procedurally correct, inferentially hollow.",
      "id": "p_cross_multiplication_rule_without_ground"
    },
    {
      "description": "Multiply digits as integers, place decimal by summing place counts. LX for decimal-positional notation.",
      "id": "p_decimal_multiplication_rule"
    },
    {
      "description": "Borrow / decompose a base into smaller units for subtraction.",
      "id": "p_decompose_base_for_ones"
    },
    {
      "description": "Diagnostic validation by distributive decomposition: validate a product by summing partial products.",
      "id": "p_decomposed_divisor_product"
    },
    {
      "description": "Limit of a continuous function at a point by substitution.",
      "id": "p_direct_substitution"
    },
    {
      "description": "Scale both operands by a power of ten, divide as integers.",
      "id": "p_ecuadorian_decimal_long_division"
    },
    {
      "description": "Diagnostic validation across two candidate estimates: compare their omitted partial products and select the smaller-omission estimate.",
      "id": "p_error_magnitude_estimate_comparison"
    },
    {
      "description": "Limit at a removable discontinuity by factoring, cancelling the common factor, then substituting.",
      "id": "p_factor_cancel_substitute"
    },
    {
      "description": "Deformation: applying factor-cancel-substitute when there is no common factor. Rule-without-its-precondition.",
      "id": "p_factor_cancel_without_common_factor"
    },
    {
      "description": "Compensation/Make-A-Base transfer. Productive partner of the unbalanced compensation deformation.",
      "id": "p_make_base_transfer"
    },
    {
      "description": "Make-Ten and split the leftover. PP-sufficient for the base-bridging move.",
      "id": "p_make_ten_split_leftover"
    },
    {
      "description": "Diagnostic validation by inverse multiplication: reject the candidate quotient when divisor * proposed exceeds dividend.",
      "id": "p_multiplicative_bound_invalidation"
    },
    {
      "description": "Walk an algebraic expression as a program: substitute variables, evaluate sub-expressions, combine via arithmetic primitives.",
      "id": "p_programming_expression_evaluation"
    },
    {
      "description": "Recall a base division fact and scale the quotient by a power of ten.",
      "id": "p_recalled_result_scaling"
    },
    {
      "description": "Diagnostic cardinality: establish a collection's cardinal by bijective counting under the five counting principles.",
      "id": "p_rigorous_counting_procedure"
    },
    {
      "description": "Round to a base, then adjust by the rounding amount.",
      "id": "p_round_then_adjust"
    },
    {
      "description": "Productive proportional reasoning: multiplicative scaling of both ratio terms preserves the unit ratio.",
      "id": "p_scale_ratio_unit"
    },
    {
      "description": "Productive signed addition that coordinates magnitude via the sign relation between addends.",
      "id": "p_signed_addition_with_sign_relation"
    },
    {
      "description": "Diagnostic justification: re-ground a procedural fraction rule by invoking the area-model kernel on the same inputs.",
      "id": "p_small_area_justification"
    },
    {
      "description": "Grounds (a/b)*(c/d) in unit-fraction logic: 1/b partitioned into d gives 1/(b*d); iterate a*c times.",
      "id": "p_unit_fraction_denominator_product_rule"
    },
    {
      "description": "Iterate a unit fraction to produce m/n. May extend beyond the whole.",
      "id": "p_unit_fraction_iteration"
    },
    {
      "description": "Partition a referent whole into equal units and select one.",
      "id": "p_unit_fraction_partition"
    }
