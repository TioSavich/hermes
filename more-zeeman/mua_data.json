      "source_concept": "basic_unit_segment",
      "target_concept": "one"
    },
    {
      "metaphor": "arithmetic_is_measuring_stick",
      "notes": "The conceptual blend forces irrationals into existence: a diagonal of a unit square has a definite physical length but no rational name, so a number must exist for it.",
      "source_concept": "every_physical_length_must_have_a_number",
      "target_concept": "irrational_numbers"
    },
    {
      "metaphor": "arithmetic_is_measuring_stick",
