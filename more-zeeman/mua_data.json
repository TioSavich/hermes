  "metaphor_breaks": [
    {
      "inference": "negative_numbers",
      "metaphor": "arithmetic_is_measuring_stick",
      "reason": "The source domain has 'lack of any physical segment' as zero; you cannot have a segment shorter than nothing, so negatives have no source-domain referent."
    },
    {
      "inference": "product_of_two_negatives",
      "metaphor": "arithmetic_is_motion_along_a_path",
      "reason": "In the source domain of motion, doing something a negative number of times makes no sense; the iterated-motion grounding of multiplication cannot be extended to negative multipliers."
    },
    {
      "inference": "fractions_of_a_unit",
      "metaphor": "arithmetic_is_object_collection",
      "reason": "Object collections are discrete; there are no 'fractional collections'."
    },
    {
      "inference": "irrational_numbers",
      "metaphor": "arithmetic_is_object_collection",
      "reason": "Irrationals have no source-domain referent as a collection."
    },
    {
      "inference": "subtraction_of_larger_from_smaller",
      "metaphor": "arithmetic_is_object_collection",
      "reason": "No source-domain referent for 'taking a larger collection from a smaller one'."
    },
    {
      "inference": "zero_as_a_number",
      "metaphor": "arithmetic_is_object_collection",
      "reason": "No source-domain referent for 'a collection of nothing'; requires the ad-hoc Zero Collection Metaphor to supply the additive identity."
    },
    {
      "inference": "irrational_numbers",
      "metaphor": "arithmetic_is_object_construction",
      "reason": "Irrationals are not constructible by finite assembly of unit parts."
    },
    {
      "inference": "zero_as_a_number",
      "metaphor": "arithmetic_is_object_construction",
      "reason": "No source-domain referent for 'an object that is the absence of an object'; requires the ad-hoc Zero Object Metaphor."
    },
    {
      "inference": "zero_as_an_object",
      "metaphor": "arithmetic_is_object_construction",
      "reason": "Zero requires the ad-hoc Zero Object Metaphor; lack-of-object is not itself a constructible object."
    }
  ],
